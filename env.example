# ============================================================
# UniRide — Root Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Shared
NODE_ENV=development

# Database (PostgreSQL)
POSTGRES_USER=uniride
POSTGRES_PASSWORD=uniride_secret
POSTGRES_DB=uniride_db
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
